# Copy this file to .env and fill in your values.
# Get a free RPC key from:
#   - Alchemy:  https://www.alchemy.com  (recommended)
#   - Infura:   https://infura.io

# Ethereum Mainnet RPC endpoint (required)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Optional: a specific block number to use instead of "latest"
# ETH_BLOCK_NUMBER=latest
